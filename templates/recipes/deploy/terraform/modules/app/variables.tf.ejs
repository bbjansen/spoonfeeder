variable "app_name" {
  type = string
}

variable "environment" {
  type = string
}

variable "region" {
  type    = string
<% if (cloudProvider === 'gcp') { -%>
  default = "europe-west1"
<% } else if (cloudProvider === 'azure') { -%>
  default = "westeurope"
<% } else { -%>
  default = "eu-west-1"
<% } -%>
}

variable "container_image" {
  type    = string
  default = "REGISTRY/IMAGE:latest"
}

variable "cpu" {
  type    = number
  default = 256
}

variable "memory" {
  type    = number
  default = 512
}

variable "desired_count" {
  type    = number
  default = 2
}

<% if (cloudProvider === 'gcp') { -%>
variable "project_id" {
  description = "GCP project ID"
  type        = string
}
<% } else if (cloudProvider === 'azure') { -%>
variable "resource_group_name" {
  description = "Azure resource group name"
  type        = string
}
<% } else { -%>
variable "private_subnet_ids" {
  type    = list(string)
  default = []
}

variable "vpc_id" {
  type    = string
  default = ""
}
<% } -%>
