{
  "$schema": "https://json-schema.org/schema",
  "cli": "nx",
  "$id": "AddRecipe",
  "title": "Add Recipe",
  "type": "object",
  "properties": {
    "recipe": {
      "type": "string",
      "description": "Recipe ID to add",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Which recipe do you want to add?"
    },
    "skipInstall": {
      "type": "boolean",
      "default": false,
      "description": "Skip pnpm install after generation"
    }
  },
  "required": ["recipe"]
}
